# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Must include your production frontend URL.
FRONTEND_ORIGIN=https://your-frontend.vercel.app

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIzaSy...
TAVILY_API_KEY=tvly-...

# ── Rate limits (reqs per 15-min window) ─────────────────────────────────────
CHAT_RATE_LIMIT=30
AGENT_RATE_LIMIT=10
SCHEME_RATE_LIMIT=20
HS_RATE_LIMIT=20
REQUEST_TIMEOUT_MS=90000
