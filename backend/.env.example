# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Sign up free at https://console.neon.tech — copy the "Connection string"
DATABASE_URL=

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Sign up free at https://dashboard.clerk.com — copy from API Keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ── AI Provider Keys ──────────────────────────────────────────────────────────
# Required — powers all AI features: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional — enables Gemini provider in chat: https://aistudio.google.com
GEMINI_API_KEY=

# Optional — enables Research Agent + News Feed: https://tavily.com (1000 free/month)
TAVILY_API_KEY=

# ── Rate Limits (requests per 15-minute window per IP) ────────────────────────
CHAT_RATE_LIMIT=30
AGENT_RATE_LIMIT=10
SCHEME_RATE_LIMIT=20
HS_RATE_LIMIT=20

# ── Timeouts ─────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=90000
